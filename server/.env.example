# PIM - Personal Inventory Manager
# Copy to .env and fill in values

PORT=8000
NODE_ENV=development
SERVER_URL=http://localhost:8003
CLIENT_URL=http://localhost:3002

# PostgreSQL - matches docker-compose defaults
DATABASE_URL="postgresql://pimuser:pimpassword@localhost:5433/pim_db"

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING
SESSION_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING

# Reuse your existing Claude API key
CLAUDE_API_KEY=your-claude-api-key-here

# Logging: error | warn | info | http | debug
LOG_LEVEL=info

# Docker PostgreSQL (used by docker-compose)
POSTGRES_DB=pim_db
POSTGRES_USER=pimuser
POSTGRES_PASSWORD=pimpassword
